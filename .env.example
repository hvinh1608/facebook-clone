# Server Config
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Database Config (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nexus?schema=public"

# JWT Config
JWT_ACCESS_SECRET="nexus_access_token_secret_key_change_me_in_production"
JWT_REFRESH_SECRET="nexus_refresh_token_secret_key_change_me_in_production"

# Email Config (Gmail: use App Password; Mailtrap for testing; empty = log link in console)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=your_email@gmail.com

# Google OAuth Config (Optional for frontend mock integration)
GOOGLE_CLIENT_ID=your_google_client_id
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000

# Cloudinary (recommended on Render: unsigned upload preset + API key)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_UPLOAD_PRESET=facebook_upload
# Secret only needed for signed uploads (optional with unsigned preset):
CLOUDINARY_API_SECRET=
# Or full URL from Cloudinary Dashboard:
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
